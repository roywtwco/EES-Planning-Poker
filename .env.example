# Client: Set this to your free backend URL (e.g., https://your-app.onrender.com)
VITE_SERVER_URL=

# Client: Base path used when deploying to GitHub Pages.
# Use /<repo-name>/ for GitHub Pages (example: /PlanningPoker/)
VITE_BASE_PATH=/PlanningPoker/

# Server: Comma-separated allowed origins for local dev + GitHub Pages.
# Example: http://localhost:5173,https://yourusername.github.io
CORS_ORIGIN=http://localhost:5173
